# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-06-01

# Auth: "entra" (Azure AD / DefaultAzureCredential) or "key" (API key)
AZURE_OPENAI_AUTH_TYPE=entra
# Only needed when AUTH_TYPE=key:
AZURE_OPENAI_API_KEY=

# Azure AI Search (for BYOD / On Your Data and eval data generation)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_INDEX=your-index-name

# Search auth: "token" (DefaultAzureCredential), "key" (API key), or "rbac" (managed identity)
AZURE_SEARCH_AUTH_TYPE=token
# Only needed when SEARCH_AUTH_TYPE=key:
AZURE_SEARCH_API_KEY=

# ── Optional: Azure AI Foundry portal integration ──────────────────────
# When set, eval results are uploaded to the Foundry portal for dashboards,
# run comparison, and per-query drill-down. Leave blank to run locally only.
FOUNDRY_SUBSCRIPTION_ID=
FOUNDRY_RESOURCE_GROUP=
FOUNDRY_PROJECT_NAME=
